    "eslint-plugin-vue": "^10.9.0",
    "postcss": "^8.4.38",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.2",
